{
  "name": "pi-effect",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "oxfmt --check package.json turbo.json tsconfig.json packages",
    "format:fix": "oxfmt package.json turbo.json tsconfig.json packages",
    "lint": "oxlint packages",
    "lint:fix": "oxlint --fix packages",
    "typecheck": "turbo run typecheck",
    "prepare": "effect-language-service patch"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.31",
    "@mariozechner/pi-agent-core": "^0.60.0",
    "@mariozechner/pi-ai": "^0.60.0",
    "effect": "4.0.0-beta.31"
  },
  "devDependencies": {
    "@effect/language-service": "^0.79.0",
    "@effect/vitest": "^4.0.0-beta.31",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "bun": ">=1.0"
  },
  "packageManager": "bun@1.2.17"
}
